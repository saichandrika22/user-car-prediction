# Email Configuration for Contact Form
# Set these values to enable email sending to mscy4u@gmail.com

# Gmail SMTP Settings
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Your Gmail address (the sender)
SENDER_EMAIL=your-gmail@gmail.com

# Your Gmail App Password (NOT your regular password)
# Generate at: https://myaccount.google.com/apppasswords
SENDER_PASSWORD=your-app-password

# Recipient email (where messages will be sent)
RECIPIENT_EMAIL=mscy4u@gmail.com

# Example:
# SENDER_EMAIL=myapp@gmail.com
# SENDER_PASSWORD=abcd efgh ijkl mnop
# RECIPIENT_EMAIL=mscy4u@gmail.com
